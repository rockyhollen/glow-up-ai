# ═══════════════════════════════════════════════
# GLOW-UP AI — Environment Variables
# Copy this to .env.local and fill in your keys
# ═══════════════════════════════════════════════

# ── Supabase ──────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key...

# ── OpenAI ────────────────────────────────────
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...your-key...

# ── Stripe ────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
# Use sk_test_ and pk_test_ while testing
STRIPE_SECRET_KEY=sk_test_...your-key...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...your-key...
STRIPE_WEBHOOK_SECRET=whsec_...your-webhook-secret...

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
